# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local databases
# (dev.db removed so the pre-seeded database goes to Netlify)

# Prevent nested repo from being staged as submodule
/PatompongWebsite

# vercel
.vercel

# uploads (user-uploaded files)
/public/uploads

# Gallery images — hosted on Supabase Storage, not in Git
/public/portfolio/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
